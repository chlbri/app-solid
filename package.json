{
  "name": "@bemedev/app-solid",
  "version": "0.5.1",
  "description": "Middleware between @bemedev/app-ts and solidjs",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/app-solid"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "app",
    "state-machines",
    "solidjs",
    "bemedev",
    "middleware",
    "reactivity"
  ],
  "files": [
    "lib",
    "public"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm run rm:lib && pnpm run rolldown",
    "ci": "CI_START=$(date +%s) && pnpm run config:off && pnpm run lint && pnpm run test && echo \"\n✅ CI takes $(($(date +%s) - CI_START))s\n\"",
    "ci:admin": "pnpm run rm && pnpm run upgrade:safe && pnpm run ci",
    "clean": "pnpm run rm && pnpm run config",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "config:vitest": "pnpm add -D @vitest/coverage-v8@3.2.4 @vitest/ui@3.2.4 vitest@3.2.4",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "gen:app": "app-typings generate",
    "gen:app:watch": "pnpm run gen:app --watch",
    "_lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:watch": "onchange --await-write-finish 5500 \"**/*\" -- pnpm run lint",
    "posttest": "pnpm run fmt",
    "prepublishOnly": "",
    "prepare": "husky",
    "pretest": "pnpm run build && pnpm run size",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "p-q": "pretty-quick",
    "rinit": "pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rimraf": "pnpx rimraf -rf",
    "rm": "pnpm run rimraf -- node_modules pnpm-lock.yaml",
    "rm:lib": "pnpm run rimraf -- lib",
    "rolldown": "rolldown -c",
    "size": "size-limit",
    "test": "pnpm run test:coverage --no-coverage",
    "test:coverage": "vitest run",
    "test:ui": "vitest ui",
    "test:watch": "vitest",
    "upgrade": "pnpm upgrade --latest",
    "upgrade:safe": "pnpm run upgrade && pnpm run config:vitest"
  },
  "size-limit": [
    {
      "path": "lib/*.js",
      "limit": "10 KB"
    },
    {
      "path": "lib/*.cjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@bemedev/app-cli": "^0.1.7",
    "@bemedev/app-ts": "^2.5.1",
    "@bemedev/decompose": "2.2.0",
    "@bemedev/dev-utils": "^0.5.3",
    "@bemedev/fsf": "^1.0.1",
    "@bemedev/sleep": "^0.2.2",
    "@size-limit/file": "^12.1.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "3.2.4",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "onchange": "^7.1.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "rolldown": "1.0.0-rc.15",
    "rolldown-plugin-dts": "^0.23.2",
    "size-limit": "^12.1.0",
    "solid-js": "^1.9.12",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "peerDependencies": {
    "@bemedev/app-ts": "^2.5.1",
    "@bemedev/decompose": "2.2.0",
    "solid-js": "^1.9.12"
  }
}
